OPENAI_API_KEY=sk-...

# Weaviate local (Docker) — default
WEAVIATE_URL=http://localhost:8080

# Weaviate Cloud (optional — leave blank if using local Docker)
WEAVIATE_API_KEY=

# Models
GPT_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small

# Chunking
CHUNK_SIZE=800
CHUNK_OVERLAP=100

# Weaviate collection name
WEAVIATE_INDEX_NAME=MedDocument
