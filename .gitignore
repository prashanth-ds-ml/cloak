# CLI config (stores user's project path and settings)
.cloak.json

# Claude Code local settings (permissions, session state — machine-specific)
.claude/

# IDE / OS
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# Test outputs
.pytest_cache/
